{
  "kind": "collectionType",
  "collectionName": "menu_items",
  "info": {
    "singularName": "menu-item",
    "pluralName": "menu-items",
    "displayName": "Menu Item"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "has_children": {
      "type": "boolean",
      "default": false
    },
    "link": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "has_children"
            },
            false
          ]
        }
      },
      "component": "shared.link",
      "repeatable": false
    },
    "submenu_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::menu-item.menu-item",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "has_children"
            },
            true
          ]
        }
      }
    }
  }
}
